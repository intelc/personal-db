{
  "manifest_version": 3,
  "name": "Personal DB XHS Collector",
  "version": "0.2.0",
  "description": "Collect your Xiaohongshu creator and saved-note feeds for Personal DB in an unfocused Chrome window.",
  "key": "",
  "permissions": ["tabs", "scripting", "userScripts", "storage", "tabGroups", "nativeMessaging", "alarms"],
  "host_permissions": ["https://www.xiaohongshu.com/*", "https://xiaohongshu.com/*", "https://creator.xiaohongshu.com/*"],
  "background": {"service_worker": "background.js"},
  "action": {"default_popup": "popup.html", "default_title": "Personal DB XHS Collector"}
}
